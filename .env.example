DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/bookclub?schema=public"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:5432/bookclub?schema=public"
SHADOW_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/bookclub_shadow?schema=public"
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_TRUST_HOST="true"

# Email delivery remains disabled until every required server-only value is
# deliberately configured. Use example.invalid placeholders only in this file.
SONDER_EMAIL_PROVIDER="disabled"
SONDER_EMAIL_FROM="Sonder Book Club <no-reply@example.invalid>"
SONDER_EMAIL_REPLY_TO=""
RESEND_API_KEY=""
RESEND_WEBHOOK_SIGNING_SECRET=""
CRON_SECRET=""
# Optional bounded worker settings.
SONDER_EMAIL_BATCH_SIZE="10"
SONDER_EMAIL_LEASE_SECONDS="120"
SONDER_EMAIL_REQUEST_TIMEOUT_MS="10000"

# Online payments are disabled unless explicitly configured for Flutterwave test
# mode. Do not use NEXT_PUBLIC_ for provider credentials.
SONDER_PAYMENT_PROVIDER="disabled"
SONDER_APP_BASE_URL="http://localhost:3000"
FLUTTERWAVE_MODE="test"
FLUTTERWAVE_SECRET_KEY=""
FLUTTERWAVE_WEBHOOK_SECRET_HASH=""
FLUTTERWAVE_PAYMENT_OPTIONS=""
