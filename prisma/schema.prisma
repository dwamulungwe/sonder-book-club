generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SystemRole {
  ADMIN
  MODERATOR
  MEMBER
  GUEST
}

enum MembershipStatus {
  PENDING
  ACTIVE
  SUSPENDED
  LEFT
}

enum BookStatus {
  NOMINATED
  BACKLOG
  CURRENT
  COMPLETED
  ARCHIVED
}

enum ReadingPlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TargetMode {
  PAGES
  CHAPTERS
}

enum ReadingPlanItemStatus {
  UPCOMING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum RsvpStatus {
  GOING
  MAYBE
  DECLINED
}

enum AttendanceStatus {
  PENDING
  ATTENDED
  ABSENT
  EXCUSED
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum MeetingNoteVisibility {
  INTERNAL
  MEMBERS_ONLY
}

enum NominationStatus {
  ACTIVE
  WITHDRAWN
  SELECTED
  ARCHIVED
}

enum PollStatus {
  DRAFT
  OPEN
  CLOSED
  CANCELLED
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CommunityPostType {
  GENERAL
  READING_UPDATE
  BOOK_RECOMMENDATION
  CURRENTLY_LISTENING
  ANNOUNCEMENT
  NEW_MEMBER_WELCOME
}

enum MembershipApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  WAITLISTED
}

enum NotificationType {
  APPLICATION_SUBMITTED
  APPLICATION_UNDER_REVIEW
  APPLICATION_APPROVED
  APPLICATION_REJECTED
  APPLICATION_WAITLISTED
  COMMUNITY_COMMENT
  COMMUNITY_REPLY
  COMMUNITY_REACTION
  ANNOUNCEMENT_PUBLISHED
  MEETING_UPDATED
  NEW_MEMBER_WELCOME
  INVOICE_CREATED
  PAYMENT_RECORDED
  PAYMENT_CONFIRMED
  PAYMENT_FAILED
  ONLINE_PAYMENT_REVIEW_REQUIRED
  SUBSCRIPTION_PAST_DUE
  SUBSCRIPTION_WAIVED
}

enum EmailOutboxStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  CANCELLED
}

enum PostReactionType {
  INSIGHTFUL
  BEAUTIFULLY_SAID
  ADDING_TO_MY_LIST
  I_AGREE
  MADE_ME_THINK
  APPLAUSE
}

enum ContentReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  WAIVED
  FAILED
  REFUNDED
  CONFIRMED
  CANCELLED
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK_TRANSFER
  CARD
  OTHER
}

enum BillingInterval {
  MONTHLY
  QUARTERLY
  ANNUAL
  ONE_TIME
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAST_DUE
  PAUSED
  CANCELLED
  WAIVED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PARTIALLY_PAID
  PAID
  VOID
  OVERDUE
}

enum OnlinePaymentProvider {
  FLUTTERWAVE
}

enum OnlinePaymentAttemptStatus {
  CREATED
  CHECKOUT_READY
  PROCESSING
  VERIFIED
  SETTLED
  FAILED
  CANCELLED
  EXPIRED
  REVIEW_REQUIRED
}

enum ProviderWebhookEventStatus {
  RECEIVED
  PROCESSED
  DUPLICATE
  FAILED
  IGNORED
}

model User {
  id                     String                  @id @default(cuid())
  name                   String
  email                  String                  @unique
  emailVerified          DateTime?
  image                  String?
  passwordHash           String?
  systemRole             SystemRole              @default(GUEST)
  membership             Membership?
  createdBooks           Book[]                  @relation("BookCreator")
  createdPlans           ReadingPlan[]           @relation("PlanCreator")
  progresses             ReadingProgress[]
  createdMeetings        Meeting[]               @relation("MeetingCreator")
  rsvps                  MeetingRsvp[]
  attendances            MeetingAttendance[]     @relation("AttendanceMember")
  recordedAttendances    MeetingAttendance[]     @relation("AttendanceRecorder")
  meetingNotesAuthored   MeetingNote[]           @relation("MeetingNoteAuthor")
  createdAnnouncements   Announcement[]          @relation("AnnouncementCreator")
  nominations            BookNomination[]
  createdPolls           Poll[]                  @relation("PollCreator")
  votes                  PollVote[]
  recordedPayments       MembershipPayment[]     @relation("PaymentRecorder")
  confirmedPayments      MembershipPayment[]     @relation("PaymentConfirmer")
  createdMembershipPlans MembershipPlan[]        @relation("MembershipPlanCreator")
  createdInvoices        MembershipInvoice[]     @relation("InvoiceCreator")
  communityPosts         CommunityPost[]         @relation("CommunityPostAuthor")
  postComments           PostComment[]           @relation("PostCommentAuthor")
  postReactions          PostReaction[]
  postBookmarks          PostBookmark[]
  contentReports         ContentReport[]         @relation("ContentReportReporter")
  reviewedReports        ContentReport[]         @relation("ContentReportReviewer")
  profile                MemberProfile?
  membershipApplications MembershipApplication[] @relation("MembershipApplicationApplicant")
  reviewedApplications   MembershipApplication[] @relation("MembershipApplicationReviewer")
  receivedNotifications  Notification[]          @relation("NotificationRecipient")
  actedNotifications     Notification[]          @relation("NotificationActor")
  notificationPreference NotificationPreference?
  emailOutboxItems       EmailOutbox[]           @relation("EmailOutboxRecipient")
  accounts               Account[]
  sessions               Session[]
  deletedAt              DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@index([systemRole])
  @@index([deletedAt])
  @@map("users")
}

model ClubSettings {
  id               String   @id
  name             String
  description      String?
  meetingFrequency String?
  location         String?
  contactEmail     String?
  contactPhone     String?
  logoUrl          String?
  bannerUrl        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("club_settings")
}

model Membership {
  id                    String                 @id @default(cuid())
  userId                String                 @unique
  role                  SystemRole             @default(MEMBER)
  status                MembershipStatus       @default(ACTIVE)
  joinedAt              DateTime               @default(now())
  payments              MembershipPayment[]
  onlinePaymentAttempts OnlinePaymentAttempt[]
  subscriptions         MemberSubscription[]
  invoices              MembershipInvoice[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([role, status])
  @@map("memberships")
}

model MemberProfile {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  bio                       String?  @db.VarChar(800)
  phoneNumber               String?  @db.VarChar(40)
  location                  String?  @db.VarChar(120)
  occupation                String?  @db.VarChar(120)
  profileImageUrl           String?  @db.VarChar(500)
  favouriteGenres           String[] @default([])
  favouriteBooks            String?  @db.VarChar(800)
  readingInterests          String?  @db.VarChar(800)
  currentlyReadingText      String?  @db.VarChar(240)
  currentlyListeningTitle   String?  @db.VarChar(180)
  currentlyListeningCreator String?  @db.VarChar(180)
  currentlyListeningUrl     String?  @db.VarChar(500)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([location])
  @@index([updatedAt])
  @@map("member_profiles")
}

model Book {
  id             String           @id @default(cuid())
  title          String
  author         String
  genre          String?
  pageCount      Int?
  coverUrl       String?
  summary        String?
  status         BookStatus       @default(BACKLOG)
  archivedAt     DateTime?
  deletedAt      DateTime?
  createdById    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  createdBy      User             @relation("BookCreator", fields: [createdById], references: [id], onDelete: Cascade)
  readingPlans   ReadingPlan[]
  nominations    BookNomination[]
  pollWins       Poll[]           @relation("WinningBook")
  pollOptions    PollOption[]
  communityPosts CommunityPost[]  @relation("CommunityPostBook")

  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("books")
}

model ReadingPlan {
  id           String            @id @default(cuid())
  bookId       String
  title        String
  targetMode   TargetMode
  status       ReadingPlanStatus @default(ACTIVE)
  weekCount    Int
  chapterCount Int?
  isActive     Boolean           @default(true)
  createdById  String
  startsOn     DateTime
  endsOn       DateTime
  deletedAt    DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  book         Book              @relation(fields: [bookId], references: [id], onDelete: Cascade)
  createdBy    User              @relation("PlanCreator", fields: [createdById], references: [id], onDelete: Cascade)
  targets      ReadingTarget[]

  @@index([status])
  @@index([isActive])
  @@index([bookId])
  @@index([deletedAt])
  @@map("reading_plans")
}

model ReadingTarget {
  id            String                @id @default(cuid())
  readingPlanId String
  sequence      Int
  label         String
  mode          TargetMode
  status        ReadingPlanItemStatus @default(UPCOMING)
  startPage     Int?
  endPage       Int?
  startChapter  Int?
  endChapter    Int?
  startsOn      DateTime
  endsOn        DateTime
  deletedAt     DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  readingPlan   ReadingPlan           @relation(fields: [readingPlanId], references: [id], onDelete: Cascade)
  progresses    ReadingProgress[]

  @@unique([readingPlanId, sequence])
  @@index([readingPlanId, startsOn])
  @@index([readingPlanId, status])
  @@index([deletedAt])
  @@map("reading_plan_items")
}

model ReadingProgress {
  id          String        @id @default(cuid())
  targetId    String
  memberId    String
  percent     Int           @default(0)
  notes       String?
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  target      ReadingTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)
  member      User          @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([targetId, memberId])
  @@index([memberId, updatedAt])
  @@index([targetId, percent])
  @@map("member_progress")
}

model Meeting {
  id           String              @id @default(cuid())
  title        String
  agenda       String?
  status       MeetingStatus       @default(SCHEDULED)
  startsAt     DateTime
  location     String?
  meetingLink  String?
  notes        String?
  createdById  String
  deletedAt    DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  createdBy    User                @relation("MeetingCreator", fields: [createdById], references: [id], onDelete: Cascade)
  rsvps        MeetingRsvp[]
  attendances  MeetingAttendance[]
  meetingNotes MeetingNote[]

  @@index([startsAt])
  @@index([status])
  @@index([deletedAt])
  @@map("meetings")
}

model MeetingRsvp {
  id        String     @id @default(cuid())
  meetingId String
  memberId  String
  status    RsvpStatus @default(MAYBE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  meeting   Meeting    @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  member    User       @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([meetingId, memberId])
  @@index([meetingId, status])
  @@index([memberId, status])
  @@map("meeting_rsvps")
}

model MeetingAttendance {
  id           String           @id @default(cuid())
  meetingId    String
  memberId     String
  status       AttendanceStatus @default(PENDING)
  recordedById String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  meeting      Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  member       User             @relation("AttendanceMember", fields: [memberId], references: [id], onDelete: Cascade)
  recordedBy   User?            @relation("AttendanceRecorder", fields: [recordedById], references: [id], onDelete: SetNull)

  @@unique([meetingId, memberId])
  @@index([meetingId, status])
  @@index([memberId, status])
  @@map("meeting_attendance")
}

model MeetingNote {
  id         String                @id @default(cuid())
  meetingId  String
  authorId   String
  title      String?
  content    String
  visibility MeetingNoteVisibility @default(MEMBERS_ONLY)
  deletedAt  DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  meeting    Meeting               @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  author     User                  @relation("MeetingNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([meetingId, createdAt])
  @@index([authorId, createdAt])
  @@index([deletedAt])
  @@map("meeting_notes")
}

model Announcement {
  id          String             @id @default(cuid())
  title       String
  body        String
  status      AnnouncementStatus @default(PUBLISHED)
  createdById String
  deletedAt   DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  createdBy   User               @relation("AnnouncementCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([status])
  @@index([deletedAt])
  @@map("announcements")
}

model CommunityPost {
  id                 String                 @id @default(cuid())
  authorId           String
  body               String                 @db.VarChar(2000)
  postType           CommunityPostType      @default(GENERAL)
  relatedBookId      String?
  listeningTitle     String?                @db.VarChar(180)
  listeningCreator   String?                @db.VarChar(180)
  listeningUrl       String?                @db.VarChar(500)
  isPinned           Boolean                @default(false)
  editedAt           DateTime?
  deletedAt          DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  author             User                   @relation("CommunityPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  relatedBook        Book?                  @relation("CommunityPostBook", fields: [relatedBookId], references: [id], onDelete: SetNull)
  comments           PostComment[]
  reactions          PostReaction[]
  bookmarks          PostBookmark[]
  reports            ContentReport[]        @relation("ContentReportPost")
  welcomeApplication MembershipApplication? @relation("MembershipApplicationWelcomePost")

  @@index([isPinned, createdAt])
  @@index([authorId, createdAt])
  @@index([postType, createdAt])
  @@index([relatedBookId])
  @@index([deletedAt])
  @@map("community_posts")
}

model MembershipApplication {
  id                     String                      @id @default(cuid())
  applicantUserId        String?
  fullName               String                      @db.VarChar(120)
  normalizedEmail        String                      @db.VarChar(255)
  email                  String                      @db.VarChar(255)
  phoneNumber            String                      @db.VarChar(40)
  location               String                      @db.VarChar(120)
  occupation             String?                     @db.VarChar(120)
  readingInterests       String                      @db.VarChar(800)
  favouriteGenres        String[]                    @default([])
  favouriteBooks         String?                     @db.VarChar(800)
  reasonForJoining       String                      @db.VarChar(1200)
  referralSource         String?                     @db.VarChar(200)
  acceptedCommunityRules Boolean
  acceptedPrivacyPolicy  Boolean
  status                 MembershipApplicationStatus @default(SUBMITTED)
  submittedAt            DateTime                    @default(now())
  reviewedAt             DateTime?
  reviewedById           String?
  reviewNotes            String?                     @db.VarChar(2000)
  welcomePostId          String?                     @unique
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  applicantUser          User?                       @relation("MembershipApplicationApplicant", fields: [applicantUserId], references: [id], onDelete: SetNull)
  reviewedBy             User?                       @relation("MembershipApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  welcomePost            CommunityPost?              @relation("MembershipApplicationWelcomePost", fields: [welcomePostId], references: [id], onDelete: SetNull)

  @@index([normalizedEmail, status])
  @@index([status, submittedAt])
  @@index([applicantUserId, createdAt])
  @@index([reviewedById, reviewedAt])
  @@map("membership_applications")
}

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  actorId     String?
  type        NotificationType
  title       String           @db.VarChar(160)
  message     String           @db.VarChar(500)
  href        String?          @db.VarChar(500)
  entityType  String?          @db.VarChar(80)
  entityId    String?          @db.VarChar(120)
  dedupeKey   String?          @unique @db.VarChar(240)
  readAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  recipient   User             @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Restrict)
  actor       User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([recipientId, readAt, createdAt])
  @@index([recipientId, createdAt])
  @@index([actorId, createdAt])
  @@index([type, createdAt])
  @@map("notifications")
}

model NotificationPreference {
  userId                  String   @id
  inAppCommunityActivity  Boolean  @default(true)
  inAppAnnouncements      Boolean  @default(true)
  inAppApplicationUpdates Boolean  @default(true)
  inAppBillingUpdates     Boolean  @default(true)
  emailCommunityActivity  Boolean  @default(false)
  emailAnnouncements      Boolean  @default(false)
  emailApplicationUpdates Boolean  @default(true)
  emailMeetingUpdates     Boolean  @default(false)
  emailBillingUpdates     Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model EmailOutbox {
  id                  String            @id @default(cuid())
  recipientUserId     String?
  toEmail             String            @db.VarChar(255)
  templateKey         String            @db.VarChar(120)
  subject             String            @db.VarChar(240)
  payload             Json
  status              EmailOutboxStatus @default(PENDING)
  dedupeKey           String            @unique @db.VarChar(240)
  attempts            Int               @default(0)
  maxAttempts         Int               @default(5)
  nextAttemptAt       DateTime?
  processingStartedAt DateTime?
  sentAt              DateTime?
  providerMessageId   String?           @db.VarChar(255)
  lastError           String?           @db.VarChar(1000)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  recipientUser       User?             @relation("EmailOutboxRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)

  @@index([status, nextAttemptAt])
  @@index([status, createdAt])
  @@index([createdAt])
  @@index([recipientUserId, createdAt])
  @@map("email_outbox")
}

model PostComment {
  id              String          @id @default(cuid())
  postId          String
  authorId        String
  parentCommentId String?
  body            String          @db.VarChar(1200)
  editedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  post            CommunityPost   @relation(fields: [postId], references: [id], onDelete: Cascade)
  author          User            @relation("PostCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parentComment   PostComment?    @relation("PostCommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies         PostComment[]   @relation("PostCommentReplies")
  reports         ContentReport[] @relation("ContentReportComment")

  @@index([postId, createdAt])
  @@index([authorId, createdAt])
  @@index([parentCommentId])
  @@index([deletedAt])
  @@map("post_comments")
}

model PostReaction {
  id           String           @id @default(cuid())
  postId       String
  userId       String
  reactionType PostReactionType
  createdAt    DateTime         @default(now())
  post         CommunityPost    @relation(fields: [postId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId, reactionType])
  @@index([userId, createdAt])
  @@map("post_reactions")
}

model PostBookmark {
  id        String        @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId, createdAt])
  @@map("post_bookmarks")
}

model ContentReport {
  id           String              @id @default(cuid())
  postId       String?
  commentId    String?
  reporterId   String
  reason       String              @db.VarChar(120)
  details      String?             @db.VarChar(1000)
  status       ContentReportStatus @default(OPEN)
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  post         CommunityPost?      @relation("ContentReportPost", fields: [postId], references: [id], onDelete: Cascade)
  comment      PostComment?        @relation("ContentReportComment", fields: [commentId], references: [id], onDelete: Cascade)
  reporter     User                @relation("ContentReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewedBy   User?               @relation("ContentReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([postId])
  @@index([commentId])
  @@index([reporterId, createdAt])
  @@index([reviewedById])
  @@map("content_reports")
}

model BookNomination {
  id          String           @id @default(cuid())
  bookId      String           @unique
  nominatorId String
  reason      String?
  status      NominationStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  book        Book             @relation(fields: [bookId], references: [id], onDelete: Cascade)
  nominator   User             @relation(fields: [nominatorId], references: [id], onDelete: Cascade)
  pollOptions PollOption[]

  @@index([createdAt])
  @@index([status])
  @@map("book_nominations")
}

model Poll {
  id            String       @id @default(cuid())
  title         String
  description   String?
  status        PollStatus   @default(DRAFT)
  opensAt       DateTime
  closesAt      DateTime
  closedAt      DateTime?
  createdById   String
  winningBookId String?
  deletedAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  createdBy     User         @relation("PollCreator", fields: [createdById], references: [id], onDelete: Cascade)
  winningBook   Book?        @relation("WinningBook", fields: [winningBookId], references: [id], onDelete: SetNull)
  options       PollOption[]
  votes         PollVote[]

  @@index([status])
  @@index([opensAt])
  @@index([closesAt])
  @@index([deletedAt])
  @@map("polls")
}

model PollOption {
  id           String         @id @default(cuid())
  pollId       String
  nominationId String
  bookId       String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  poll         Poll           @relation(fields: [pollId], references: [id], onDelete: Cascade)
  nomination   BookNomination @relation(fields: [nominationId], references: [id], onDelete: Cascade)
  book         Book           @relation(fields: [bookId], references: [id], onDelete: Cascade)
  votes        PollVote[]

  @@unique([pollId, bookId])
  @@index([pollId])
  @@map("poll_options")
}

model PollVote {
  id        String     @id @default(cuid())
  pollId    String
  optionId  String
  voterId   String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  voter     User       @relation(fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([pollId, voterId])
  @@index([optionId, createdAt])
  @@index([voterId, createdAt])
  @@map("votes")
}

model MembershipPayment {
  id                   String                @id @default(cuid())
  membershipId         String
  invoiceId            String?
  amountMinor          BigInt
  currency             String                @default("ZMW") @db.VarChar(3)
  status               PaymentStatus         @default(PENDING)
  method               PaymentMethod?
  externalReference    String?               @map("reference")
  internalReference    String                @unique @db.VarChar(80)
  dueAt                DateTime?
  paidAt               DateTime?
  confirmedAt          DateTime?
  confirmedById        String?
  periodStart          DateTime?
  periodEnd            DateTime?
  notes                String?
  recordedById         String?
  idempotencyKey       String?               @unique @db.VarChar(160)
  deletedAt            DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  membership           Membership            @relation(fields: [membershipId], references: [id], onDelete: Restrict)
  invoice              MembershipInvoice?    @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  recordedBy           User?                 @relation("PaymentRecorder", fields: [recordedById], references: [id], onDelete: SetNull)
  confirmedBy          User?                 @relation("PaymentConfirmer", fields: [confirmedById], references: [id], onDelete: SetNull)
  onlinePaymentAttempt OnlinePaymentAttempt?

  @@index([membershipId, periodStart, periodEnd])
  @@index([externalReference])
  @@index([membershipId, status])
  @@index([invoiceId, status])
  @@index([dueAt, status])
  @@index([confirmedAt])
  @@index([deletedAt])
  @@map("membership_payments")
}

model MembershipPlan {
  id              String               @id @default(cuid())
  name            String               @db.VarChar(120)
  description     String?              @db.VarChar(500)
  amountMinor     BigInt
  currency        String               @default("ZMW") @db.VarChar(3)
  billingInterval BillingInterval
  intervalCount   Int                  @default(1)
  isActive        Boolean              @default(true)
  isDefault       Boolean              @default(false)
  createdById     String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  createdBy       User?                @relation("MembershipPlanCreator", fields: [createdById], references: [id], onDelete: SetNull)
  subscriptions   MemberSubscription[]

  @@index([isActive, isDefault])
  @@index([billingInterval])
  @@index([createdById])
  @@map("membership_plans")
}

model MemberSubscription {
  id                 String              @id @default(cuid())
  membershipId       String
  planId             String
  status             SubscriptionStatus  @default(PENDING)
  startedAt          DateTime            @default(now())
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  nextBillingAt      DateTime?
  cancelledAt        DateTime?
  pausedAt           DateTime?
  waiverReason       String?             @db.VarChar(500)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  membership         Membership          @relation(fields: [membershipId], references: [id], onDelete: Restrict)
  plan               MembershipPlan      @relation(fields: [planId], references: [id], onDelete: Restrict)
  invoices           MembershipInvoice[]

  @@index([membershipId, status])
  @@index([planId, status])
  @@index([nextBillingAt])
  @@index([currentPeriodEnd])
  @@map("member_subscriptions")
}

model MembershipInvoice {
  id                    String                 @id @default(cuid())
  membershipId          String
  subscriptionId        String?
  invoiceNumber         String                 @unique @db.VarChar(40)
  status                InvoiceStatus          @default(OPEN)
  description           String                 @db.VarChar(240)
  amountDueMinor        BigInt
  amountPaidMinor       BigInt                 @default(0)
  currency              String                 @default("ZMW") @db.VarChar(3)
  periodStart           DateTime?
  periodEnd             DateTime?
  dueAt                 DateTime
  paidAt                DateTime?
  voidedAt              DateTime?
  createdById           String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  membership            Membership             @relation(fields: [membershipId], references: [id], onDelete: Restrict)
  subscription          MemberSubscription?    @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  createdBy             User?                  @relation("InvoiceCreator", fields: [createdById], references: [id], onDelete: SetNull)
  payments              MembershipPayment[]
  onlinePaymentAttempts OnlinePaymentAttempt[]

  @@index([membershipId, status])
  @@index([status, dueAt])
  @@index([dueAt])
  @@index([subscriptionId, periodStart, periodEnd])
  @@index([createdById])
  @@map("membership_invoices")
}

model OnlinePaymentAttempt {
  id                     String                     @id @default(cuid())
  provider               OnlinePaymentProvider
  sonderReference        String                     @unique @db.VarChar(80)
  membershipId           String
  invoiceId              String
  amountMinor            BigInt
  currency               String                     @db.VarChar(3)
  status                 OnlinePaymentAttemptStatus @default(CREATED)
  providerTransactionId  String?                    @db.VarChar(120)
  providerReference      String?                    @db.VarChar(160)
  providerCheckoutId     String?                    @db.VarChar(160)
  checkoutUrl            String?                    @db.VarChar(1000)
  checkoutExpiresAt      DateTime?
  checkoutIdempotencyKey String?                    @unique @db.VarChar(128)
  settledPaymentId       String?                    @unique
  failureReason          String?                    @db.VarChar(120)
  reviewReason           String?                    @db.VarChar(120)
  providerStatus         String?                    @db.VarChar(80)
  verifiedAt             DateTime?
  settledAt              DateTime?
  lastStatusCheckedAt    DateTime?
  sanitizedStatus        Json?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  membership             Membership                 @relation(fields: [membershipId], references: [id], onDelete: Restrict)
  invoice                MembershipInvoice          @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  settledPayment         MembershipPayment?         @relation(fields: [settledPaymentId], references: [id], onDelete: Restrict)
  webhookEvents          ProviderWebhookEvent[]

  @@index([membershipId, status, createdAt])
  @@index([invoiceId, status, createdAt])
  @@index([provider, status, lastStatusCheckedAt])
  @@index([providerTransactionId])
  @@index([settledPaymentId])
  @@map("online_payment_attempts")
}

model ProviderWebhookEvent {
  id                    String                     @id @default(cuid())
  provider              OnlinePaymentProvider
  eventKey              String                     @db.VarChar(160)
  providerEventId       String?                    @db.VarChar(160)
  eventType             String?                    @db.VarChar(120)
  providerTransactionId String?                    @db.VarChar(120)
  sonderReference       String?                    @db.VarChar(80)
  payloadHash           String                     @db.VarChar(64)
  status                ProviderWebhookEventStatus @default(RECEIVED)
  failureReason         String?                    @db.VarChar(120)
  attemptId             String?
  receivedAt            DateTime                   @default(now())
  processedAt           DateTime?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  attempt               OnlinePaymentAttempt?      @relation(fields: [attemptId], references: [id], onDelete: SetNull)

  @@unique([provider, eventKey])
  @@index([provider, status, receivedAt])
  @@index([providerTransactionId])
  @@index([sonderReference])
  @@index([attemptId])
  @@map("provider_webhook_events")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
